{
  "name": "@reuters-graphics/bluprint",
  "version": "0.6.7",
  "description": "Dead-easy application scaffolding and CLI.",
  "homepage": "https://github.com/reuters-graphics/bluprint#readme",
  "bugs": {
    "url": "https://github.com/reuters-graphics/bluprint/issues"
  },
  "author": "Jon McClure <jon.r.mcclure@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git@github.com:reuters-graphics/bluprint.git"
  },
  "type": "module",
  "main": "./dist/index.js",
  "exports": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "bluprint": "dist/cli.js"
  },
  "files": [
    "dist/**/*"
  ],
  "private": false,
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@9.13.2",
  "keywords": [
    "scaffold",
    "scaffolding",
    "boilerplate",
    "blueprints",
    "template",
    "git",
    "github",
    "repo",
    "repository",
    "dev",
    "development",
    "cli",
    "tool",
    "tooling",
    "generator",
    "tarball"
  ],
  "scripts": {
    "prepublishOnly": "pnpm run build",
    "build": "rollup --config rollup.config.js",
    "build:docs": "astro build",
    "docs:dev": "astro dev",
    "docs:preview": "astro preview",
    "test": "vitest",
    "coverage": "vitest run --coverage",
    "lint": "eslint --fix",
    "format": "prettier . --write",
    "changeset:version": "changeset version",
    "changeset:publish": "git add --all && changeset publish"
  },
  "devDependencies": {
    "@astrojs/starlight": "^0.32.2",
    "@changesets/cli": "^2.27.9",
    "@reuters-graphics/yaks-eslint": "^0.0.6",
    "@reuters-graphics/yaks-prettier": "^0.0.4",
    "@reuters-graphics/yaks-ts": "^0.0.4",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^11.1.3",
    "@types/ejs": "^3.1.5",
    "@types/hosted-git-info": "^3.0.5",
    "@types/mock-fs": "^4.13.4",
    "@types/mustache": "^4.2.5",
    "@types/node": "^22.9.0",
    "@types/prompts": "^2.4.9",
    "@types/semver": "^7.7.1",
    "@types/string": "^0.0.34",
    "@types/tar": "^6.1.13",
    "@types/update-notifier": "^6.0.8",
    "@vitest/coverage-v8": "^3.0.5",
    "astro": "^5.4.0",
    "eslint": "^9.39.1",
    "mock-fs": "^5.1.2",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.3.3",
    "rollup": "^4.53.2",
    "rollup-plugin-node-externals": "^8.1.2",
    "tslib": "^2.6.2",
    "typescript": "^5.7.3",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.0.5"
  },
  "dependencies": {
    "chalk": "^2.4.2",
    "ejs": "^2.6.1",
    "es-toolkit": "^1.32.0",
    "glob": "^7.1.6",
    "hosted-git-info": "^6.1.1",
    "minimatch": "^10.1.1",
    "mustache": "^4.0.0",
    "prompts": "^2.3.0",
    "sade": "^1.8.1",
    "semver": "^7.1.3",
    "string": "^3.3.3",
    "tar": "^5.0.5",
    "update-notifier": "^4.0.0",
    "valibot": "1.1.0",
    "winston": "^3.2.1"
  }
}